[
  {
    "name": "theme_info",
    "theme_name": "Blinc Theme",
    "theme_version": "1.0.0",
    "theme_author": "Blinc",
    "theme_documentation_url": "https://blinc.design",
    "theme_support_url": "https://blinc.design"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Background gradient",
            "default": ""
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button",
            "label": "Solid button background",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "Solid button label",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "Outline button",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "border",
            "label": "Border",
            "default": "#E6E6E6"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "primary_button": "button",
          "on_primary_button": "button_label",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "primary_button_border": "button",
          "secondary_button_border": "secondary_button_label",
          "links": "text",
          "icons": "text"
        }
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "font_heading_family",
        "label": "Font",
        "default": "assistant_n4"
      },
      {
        "type": "header",
        "content": "Body text"
      },
      {
        "type": "font_picker",
        "id": "font_body_family",
        "label": "Font",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "default": 1400
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  }
]
