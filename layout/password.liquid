<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>

    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {% render 'color-schemes' %}

    {%- style -%}
      {{ settings.font_body_family | font_face: font_display: 'swap' }}
      {{ settings.font_heading_family | font_face: font_display: 'swap' }}

      :root {
        --font-body-family: {{ settings.font_body_family.family }}, {{ settings.font_body_family.fallback_families }};
        --font-heading-family: {{ settings.font_heading_family.family }}, {{ settings.font_heading_family.fallback_families }};
        --page-width: {{ settings.page_width }}px;
      }
    {%- endstyle -%}
  </head>

  <body class="template-password">
    <main id="MainContent">
      {{ content_for_layout }}
    </main>
  </body>
</html>
